# API de Ocorrências (Hexagon) – usado ao clicar em "Mostrar ocorrências" e aplicar filtro
# Copie para .env e preencha com as credenciais fornecidas (não commitar .env)
VITE_OCORRENCIAS_API_BASE_URL=http://35.199.126.236:8085/api
VITE_OCORRENCIAS_API_USERNAME=username_here
VITE_OCORRENCIAS_API_PASSWORD=password_here

# Planilha de ocorrências (fonte "Planilha"): use somente a pasta public/planilhas/
# Ex.: public/planilhas/RelacaoOcorrenciasFinalizadas.xlsx => /planilhas/RelacaoOcorrenciasFinalizadas.xlsx
# VITE_OCORRENCIAS_PLANILHA_URL=/planilhas/RelacaoOcorrenciasFinalizadas.xlsx
# Se houver nomes diferentes entre ambientes, informe uma lista separada por vírgula:
# VITE_OCORRENCIAS_PLANILHA_URLS=RelacaoOcorrenciasFinalizadas.xlsx,ocorrencias.xlsx,minha_planilha.xlsx

# Geocoding (histórico Hexagon): ativo por padrão para localizar ocorrências no mapa (endereço → lat/lng). Para desativar: false
# VITE_GEOCODE_OCORRENCIAS=false
